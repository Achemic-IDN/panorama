// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QueueLogStatus {
  WAITING
  PROCESSING
  COMPLETED
  CANCELLED
}

model Queue {
  id        Int      @id @default(autoincrement())
  queue     String   @unique
  mrn       String
  status    String   @default("Menunggu")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Feedback {
  id      Int      @id @default(autoincrement())
  queue   String
  mrn     String
  message String
  rating  Int      @default(5)
  time    DateTime @default(now())
}

model PatientLogin {
  id        Int      @id @default(autoincrement())
  queue     String
  mrn       String
  loginTime DateTime @default(now())
  status    String   @default("Waiting")
}

model QueueLog {
  id                  Int            @id @default(autoincrement())
  queueNumber         String         @map("queue_number") @unique
  patientName         String?        @map("patient_name")
  medicalRecordNumber String         @map("medical_record_number")
  serviceType         String?        @map("service_type")
  status              QueueLogStatus @default(WAITING)
  createdAt           DateTime       @default(now()) @map("created_at")
  calledAt            DateTime?      @map("called_at")
  completedAt         DateTime?      @map("completed_at")
  adminId             Int?           @map("admin_id")
  queueId             Int?           @map("queue_id")

  @@map("queue_logs")
}
