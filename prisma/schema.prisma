// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QueueLogStatus {
  WAITING
  PROCESSING
  COMPLETED
  CANCELLED
}

// PANORAMA queue status enum
enum QueueStatus {
  MENUNGGU   // waiting for processing
  ENTRY
  TRANSPORT
  PACKAGING
  PENYERAHAN // previously READY
  SELESAI    // previously COMPLETED
  CANCELLED
}

// old StaffRole is replaced by AdminRole; kept around for migration scripts if needed
// enum StaffRole {
//   ENTRY
//   TRANSPORT
//   PACKAGING
//   PICKUP
//   ADMIN
// }

enum AdminRole {
  UTAMA        // super‑admin / monitor all stages
  ENTRY        // can move MENUNGGU → ENTRY → TRANSPORT
  TRANSPORT    // can move ENTRY → TRANSPORT → PACKAGING
  PACKAGING    // can move TRANSPORT → PACKAGING → PENYERAHAN
  PENYERAHAN   // can move PENYERAHAN → SELESAI
}

model Queue {
  id        Int         @id @default(autoincrement())
  queue     String      @unique
  mrn       String
  status    QueueStatus @default(MENUNGGU)
  
  // Stage timestamps - when queue enters each stage
  entryAt          DateTime?
  transportAt      DateTime?
  packagingAt      DateTime?
  readyAt          DateTime?
  completedAt      DateTime?
  
  // Detailed timestamps for time tracking
  // Start times - when queue begins processing at each stage
  entryStartAt          DateTime?
  transportStartAt      DateTime?
  packagingStartAt     DateTime?
  penyerahanStartAt     DateTime?
  
  // End times - when queue finishes processing at each stage
  entryEndAt          DateTime?
  transportEndAt      DateTime?
  packagingEndAt     DateTime?
  penyerahanEndAt     DateTime?
  
  // Duration in seconds for each stage
  durationEntry        Int?       // seconds spent in ENTRY stage
  durationTransport   Int?       // seconds spent in TRANSPORT stage
  durationPackaging   Int?       // seconds spent in PACKAGING stage
  durationPenyerahan  Int?       // seconds spent in PENYERAHAN stage
  durationTotal       Int?       // total seconds from MENUNGGU to SELESAI
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  // relations to notification and audit log models
  notifications PatientStageNotification[]
  auditLogs      QueueAuditLog[]
}

model Feedback {
  id      Int      @id @default(autoincrement())
  queue   String
  mrn     String
  message String
  rating  Int      @default(5)
  time    DateTime @default(now())
}

model PatientLogin {
  id        Int      @id @default(autoincrement())
  queue     String
  mrn       String
  loginTime DateTime @default(now())
  status    String   @default("MENUNGGU")
}

model QueueLog {
  id                  Int            @id @default(autoincrement())
  queueNumber         String         @map("queue_number") @unique
  patientName         String?        @map("patient_name")
  medicalRecordNumber String         @map("medical_record_number")
  serviceType         String?        @map("service_type")
  status              QueueLogStatus @default(WAITING)
  createdAt           DateTime       @default(now()) @map("created_at")
  calledAt            DateTime?      @map("called_at")
  completedAt         DateTime?      @map("completed_at")
  adminId             Int?           @map("admin_id")
  queueId             Int?           @map("queue_id")

  @@map("queue_logs")
}

// Log setiap perpindahan stage antrean
model QueueStageLog {
  id        Int         @id @default(autoincrement())
  queueId   Int
  stage     QueueStatus
  staffId   Int?        @map("staff_id")
  notes     String?
  timestamp DateTime    @default(now())

  @@map("queue_stage_logs")
}

model Patient {
  id           Int      @id @default(autoincrement())
  mrn          String   @unique
  name         String
  phone        String?
  clinicOrigin String?  @map("clinic_origin")

  // reverse relation for stage notifications
  stageNotifications PatientStageNotification[]

  @@map("patients")
}

model Staff {
  id           Int          @id @default(autoincrement())
  name         String
  // allow multiple roles per user so we can implement role selection
  roles        AdminRole[]
  username     String       @unique
  passwordHash String       @map("password_hash")
  createdAt    DateTime     @default(now()) @map("created_at")

  // reverse relation for audit logs
  auditLogs     QueueAuditLog[]

  @@map("staff") // keep existing table name for backwards compatibility
}

model Prescription {
  id        Int      @id @default(autoincrement())
  queueId   Int?     @map("queue_id")
  drugList  String   @map("drug_list") // JSON string
  notes     String?  // instructions / additional notes
  createdAt DateTime @default(now()) @map("created_at")

  @@map("prescriptions")
}

model Notification {
  id        Int      @id @default(autoincrement())
  queueId   Int?     @map("queue_id")
  phone     String
  message   String
  status    String   @default("PENDING")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("notifications")
}

// Patient notifications for each stage transition (non-SMS, in-app history)
model PatientStageNotification {
  id        String     @id @default(cuid())
  queueId   Int        @map("queue_id")
  patientId Int?       @map("patient_id")
  stage     QueueStatus
  message   String
  createdAt DateTime   @default(now()) @map("created_at")

  queue   Queue    @relation(fields: [queueId], references: [id])
  patient Patient? @relation(fields: [patientId], references: [id])

  @@index([queueId])
  @@index([patientId])
  @@map("patient_stage_notifications")
}

// Audit log for stage transitions and queue actions (separate from aggregate queue_logs)
model QueueAuditLog {
  id        String      @id @default(cuid())
  queueId   Int         @map("queue_id")
  staffId   Int?        @map("staff_id")
  action    String
  fromStage QueueStatus? @map("from_stage")
  toStage   QueueStatus? @map("to_stage")
  notes     String?
  createdAt DateTime    @default(now()) @map("created_at")

  queue Queue  @relation(fields: [queueId], references: [id])
  staff Staff? @relation(fields: [staffId], references: [id])

  @@index([queueId])
  @@index([staffId])
  @@map("queue_audit_logs")
}
