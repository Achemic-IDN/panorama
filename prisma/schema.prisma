// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum QueueLogStatus {
  WAITING
  PROCESSING
  COMPLETED
  CANCELLED
}

// PANORAMA queue status enum
enum QueueStatus {
  WAITING
  ENTRY
  TRANSPORT
  PACKAGING
  READY
  COMPLETED
  CANCELLED
}

enum StaffRole {
  ENTRY
  TRANSPORT
  PACKAGING
  PICKUP
  ADMIN
}

model Queue {
  id        Int         @id @default(autoincrement())
  queue     String      @unique
  mrn       String
  status    QueueStatus @default(WAITING)
  entryAt   DateTime?
  transportAt DateTime?
  packagingAt DateTime?
  readyAt   DateTime?
  completedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Feedback {
  id      Int      @id @default(autoincrement())
  queue   String
  mrn     String
  message String
  rating  Int      @default(5)
  time    DateTime @default(now())
}

model PatientLogin {
  id        Int      @id @default(autoincrement())
  queue     String
  mrn       String
  loginTime DateTime @default(now())
  status    String   @default("WAITING")
}

model QueueLog {
  id                  Int            @id @default(autoincrement())
  queueNumber         String         @map("queue_number") @unique
  patientName         String?        @map("patient_name")
  medicalRecordNumber String         @map("medical_record_number")
  serviceType         String?        @map("service_type")
  status              QueueLogStatus @default(WAITING)
  createdAt           DateTime       @default(now()) @map("created_at")
  calledAt            DateTime?      @map("called_at")
  completedAt         DateTime?      @map("completed_at")
  adminId             Int?           @map("admin_id")
  queueId             Int?           @map("queue_id")

  @@map("queue_logs")
}

// Log setiap perpindahan stage antrean
model QueueStageLog {
  id        Int         @id @default(autoincrement())
  queueId   Int
  stage     QueueStatus
  staffId   Int?        @map("staff_id")
  notes     String?
  timestamp DateTime    @default(now())

  @@map("queue_stage_logs")
}

model Patient {
  id           Int      @id @default(autoincrement())
  mrn          String   @unique
  name         String
  phone        String?
  clinicOrigin String?  @map("clinic_origin")

  @@map("patients")
}

model Staff {
  id           Int       @id @default(autoincrement())
  name         String
  role         StaffRole
  username     String    @unique
  passwordHash String    @map("password_hash")
  createdAt    DateTime  @default(now()) @map("created_at")

  @@map("staff")
}

model Prescription {
  id        Int      @id @default(autoincrement())
  queueId   Int?     @map("queue_id")
  drugList  String   @map("drug_list") // JSON string
  notes     String?  // instructions / additional notes
  createdAt DateTime @default(now()) @map("created_at")

  @@map("prescriptions")
}

model Notification {
  id        Int      @id @default(autoincrement())
  queueId   Int?     @map("queue_id")
  phone     String
  message   String
  status    String   @default("PENDING")
  sentAt    DateTime? @map("sent_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("notifications")
}
